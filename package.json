    "test:e2e:ui": "playwright test --ui",
    "sitemap": "node scripts/generate-sitemap.js"
  },
  "keywords": [
    "sdframe",
    "software-design",
    "software-architecture",
    "design-patterns",
    "system-design",
    "ai-agents"
